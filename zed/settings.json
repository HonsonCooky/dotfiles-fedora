{
  "terminal": {
    "flexible": true
  },
  "agent_servers": {
    "claude-acp": {
      "default_config_options": {
        "model": "default"
      },
      "type": "registry"
    }
  },
  "agent": {
    "dock": "right",
  },
  "preferred_line_length": 120,
  "theme": {
    "mode": "system",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "auto_install_extensions": {
    "luau": true,
  },
  "lsp": {
    "luau-lsp": {
      "settings": {
        "roblox": {
          "enabled": true,
          "security_level": "none",
        },
      },
    },
  },
}
